anxiahuodong/list'\n    import discussjiaoyouxinxi from '@/views/modules/discussjiaoyouxinxi/list'\n    import jiaoyouxinxi from '@/views/modules/jiaoyouxinxi/list'\n    import config from '@/views/modules/config/list'\n\n\n//2.配置路由   注意：名字\nconst routes = [{\n    path: '/index',\n    name: '首页',\n    component: Index,\n    children: [{\n      // 这里不设置值，是把main作为默认页面\n      path: '',\n      name: '首页',\n      component: Home,\n      meta: {icon:'', title:'center'}\n    }, {\n      path: 'updatePassword',\n      name: '修改密码',\n      component: UpdatePassword,\n      meta: {icon:'', title:'updatePassword'}\n    }, {\n      path: 'pay',\n      name: '支付',\n      component: pay,\n      meta: {icon:'', title:'pay'}\n    }, {\n      path: 'center',\n      name: '个人信息',\n      component: center,\n      meta: {icon:'', title:'center'}\n    }\n      ,{\n    path: 'forum',\n        name: '交流论坛',\n        component: forum\n      }\n      ,{\n    path: 'news',\n        name: '公告信息',\n        component: news\n      }\n      ,{\n    path: 'yonghu',\n        name: '用户',\n        component: yonghu\n      }\n      ,{\n    path: 'discussxianxiahuodong',\n        name: '线下活动评论',\n        component: discussxianxiahuodong\n      }\n      ,{\n    path: 'huodongbaoming',\n        name: '活动报名',\n        component: huodongbaoming\n      }\n      ,{\n    path: 'xianxiahuodong',\n        name: '线下活动',\n        component: xianxiahuodong\n      }\n      ,{\n    path: 'discussjiaoyouxinxi',\n        name: '交友信息评论',\n        component: discussjiaoyouxinxi\n      }\n      ,{\n    path: 'jiaoyouxinxi',\n        name: '交友信息',\n        component: jiaoyouxinxi\n      }\n      ,{\n    path: 'config',\n        name: '轮播图管理',\n        component: config\n      }\n    ]\n  },\n  {\n    path: '/login',\n    name: 'login',\n    component: Login,\n    meta: {icon:'', title:'login'}\n  },\n  {\n    path: '/register',\n    name: 'register',\n    component: register,\n    meta: {icon:'', title:'register'}\n  },\n  {\n    path: '/',\n    name: 'root',\n    redirect: '/login'\n  }, /*默认跳转路由*/\n  {\n    path: '*',\n    component: NotFound\n  }\n]\n//3.实例化VueRouter  注意：名字\nconst router = new VueRouter({\n  mode: 'hash',\n  /*hash模式改为history*/\n  routes // （缩写）相当于 routes: routes\n})\n\nrouter.beforeEach((to, from, next) => {\n  const token = storage.get('token')\n  if (to.name === 'login' || to.name === 'register') {\n    if (token && to.name === 'login') {\n      next({ path: '/index' })\n      return\n    }\n    next()\n    return\n  }\n  if (!token) {\n    next({ name: 'login' })\n    return\n  }\n  next()\n})\n\nexport default router;\n"],"mappings":";AAAA,OAAOA,GAAG,MAAM,KAAK;AACrB;AACA,OAAOC,SAAS,MAAM,YAAY;AAClC,OAAOC,OAAO,MAAM,iBAAiB;AACrCF,GAAG,CAACG,GAAG,CAACF,SAAS,CAAC;AAClB;AACA,OAAOG,KAAK,MAAM,eAAe;AACjC,OAAOC,IAAI,MAAM,cAAc;AAC/B,OAAOC,KAAK,MAAM,eAAe;AACjC,OAAOC,QAAQ,MAAM,aAAa;AAClC,OAAOC,cAAc,MAAM,yBAAyB;AACpD,OAAOC,GAAG,MAAM,aAAa;AAC7B,OAAOC,QAAQ,MAAM,kBAAkB;AACvC,OAAOC,MAAM,MAAM,gBAAgB;AAC/B,OAAOC,KAAK,MAAM,4BAA4B;AAC9C,OAAOC,IAAI,MAAM,2BAA2B;AAC5C,OAAOC,MAAM,MAAM,6BAA6B;AAChD,OAAOC,qBAAqB,MAAM,4CAA4C;AAC9E,OAAOC,cAAc,MAAM,qCAAqC;AAChE,OAAOC,cAAc,MAAM,qCAAqC;AAChE,OAAOC,mBAAmB,MAAM,0CAA0C;AAC1E,OAAOC,YAAY,MAAM,mCAAmC;AAC5D,OAAOC,MAAM,MAAM,6BAA6B;;AAGpD;AACA,IAAMC,MAAM,GAAG,CAAC;EACZC,IAAI,EAAE,QAAQ;EACdC,IAAI,EAAE,IAAI;EACVC,SAAS,EAAEpB,KAAK;EAChBqB,QAAQ,EAAE,CAAC;IACT;IACAH,IAAI,EAAE,EAAE;IACRC,IAAI,EAAE,IAAI;IACVC,SAAS,EAAEnB,IAAI;IACfqB,IAAI,EAAE;MAACC,IAAI,EAAC,EAAE;MAAEC,KAAK,EAAC;IAAQ;EAChC,CAAC,EAAE;IACDN,IAAI,EAAE,gBAAgB;IACtBC,IAAI,EAAE,MAAM;IACZC,SAAS,EAAEhB,cAAc;IACzBkB,IAAI,EAAE;MAACC,IAAI,EAAC,EAAE;MAAEC,KAAK,EAAC;IAAgB;EACxC,CAAC,EAAE;IACDN,IAAI,EAAE,KAAK;IACXC,IAAI,EAAE,IAAI;IACVC,SAAS,EAAEf,GAAG;IACdiB,IAAI,EAAE;MAACC,IAAI,EAAC,EAAE;MAAEC,KAAK,EAAC;IAAK;EAC7B,CAAC,EAAE;IACDN,IAAI,EAAE,QAAQ;IACdC,IAAI,EAAE,MAAM;IACZC,SAAS,EAAEb,MAAM;IACjBe,IAAI,EAAE;MAACC,IAAI,EAAC,EAAE;MAAEC,KAAK,EAAC;IAAQ;EAChC,CAAC,EACE;IACHN,IAAI,EAAE,OAAO;IACTC,IAAI,EAAE,MAAM;