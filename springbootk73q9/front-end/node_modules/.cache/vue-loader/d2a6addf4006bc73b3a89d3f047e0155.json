{"remainingRequest":"E:\\BYSJ\\springbootk73q9\\front-end\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!E:\\BYSJ\\springbootk73q9\\front-end\\src\\views\\login.vue?vue&type=style&index=0&id=7589b93f&scoped=true&lang=css","dependencies":[{"path":"E:\\BYSJ\\springbootk73q9\\front-end\\src\\views\\login.vue","mtime":1777465941635},{"path":"E:\\BYSJ\\springbootk73q9\\front-end\\node_modules\\css-loader\\dist\\cjs.js","mtime":1777463940764},{"path":"E:\\BYSJ\\springbootk73q9\\front-end\\node_modules\\vue-loader\\lib\\loaders\\stylePostLoader.js","mtime":1777463942725},{"path":"E:\\BYSJ\\springbootk73q9\\front-end\\node_modules\\postcss-loader\\src\\index.js","mtime":1777463941429},{"path":"E:\\BYSJ\\springbootk73q9\\front-end\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1777463939920},{"path":"E:\\BYSJ\\springbootk73q9\\front-end\\node_modules\\vue-loader\\lib\\index.js","mtime":1777463941957}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["login.vue"],"names":[],"mappings":";AA8DA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA","file":"login.vue","sourceRoot":"src/views","sourcesContent":["<template>\n  <div class=\"login-container\">\n    <div class=\"login-box\">\n      <h2>校友社交系统登录</h2>\n      <form @submit.prevent=\"handleLogin\">\n        <div class=\"form-group\">\n          <label>用户名</label>\n          <input type=\"text\" v-model=\"form.username\" placeholder=\"请输入用户名\" required>\n        </div>\n        <div class=\"form-group\">\n          <label>密码</label>\n          <input type=\"password\" v-model=\"form.password\" placeholder=\"请输入密码\" required>\n        </div>\n        <div class=\"form-group\">\n          <label>角色</label>\n          <div class=\"radio-group\">\n            <label><input type=\"radio\" v-model=\"form.role\" value=\"管理员\"> 管理员</label>\n            <label><input type=\"radio\" v-model=\"form.role\" value=\"用户\"> 用户</label>\n          </div>\n        </div>\n        <button type=\"submit\" class=\"login-btn\">登录</button>\n      </form>\n      <p class=\"register-link\">还没有账号？<a href=\"/register\">立即注册</a></p>\n    </div>\n  </div>\n</template>\n\n<script>\nimport http from '../utils/http'\n\nexport default {\n  name: 'LoginPage',\n  data() {\n    return {\n      form: {\n        username: '',\n        password: '',\n        role: '用户'\n      }\n    }\n  },\n  methods: {\n    async handleLogin() {\n      try {\n        const response = await http.post('/login', this.form)\n        if (response.code === 0) {\n          localStorage.setItem('token', response.data.token)\n          localStorage.setItem('user', JSON.stringify(response.data.user))\n          this.$router.push('/')\n        } else {\n          alert(response.message || '登录失败')\n        }\n      } catch (error) {\n        console.error('登录失败:', error)\n        alert('登录失败，请重试')\n      }\n    }\n  }\n}\n</script>\n\n<style scoped>\n.login-container {\n  min-height: 100vh;\n  display: flex;\n  justify-content: center;\n  align-items: center;\n  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\n}\n\n.login-box {\n  background: white;\n  padding: 2.5rem;\n  border-radius: 15px;\n  box-shadow: 0 10px 40px rgba(0,0,0,0.2);\n  width: 100%;\n  max-width: 400px;\n}\n\n.login-box h2 {\n  text-align: center;\n  color: #333;\n  margin-bottom: 2rem;\n  font-size: 1.8rem;\n}\n\n.form-group {\n  margin-bottom: 1.2rem;\n}\n\n.form-group label {\n  display: block;\n  margin-bottom: 0.5rem;\n  color: #555;\n  font-weight: 500;\n}\n\n.form-group input {\n  width: 100%;\n  padding: 0.8rem;\n  border: 2px solid #e0e0e0;\n  border-radius: 8px;\n  font-size: 1rem;\n  transition: border-color 0.3s;\n  box-sizing: border-box;\n}\n\n.form-group input:focus {\n  outline: none;\n  border-color: #667eea;\n}\n\n.radio-group {\n  display: flex;\n  gap: 2rem;\n}\n\n.radio-group label {\n  display: flex;\n  align-items: center;\n  gap: 0.5rem;\n  cursor: pointer;\n}\n\n.login-btn {\n  width: 100%;\n  padding: 0.9rem;\n  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\n  color: white;\n  border: none;\n  border-radius: 8px;\n  font-size: 1rem;\n  font-weight: 600;\n  cursor: pointer;\n  transition: transform 0.3s, box-shadow 0.3s;\n}\n\n.login-btn:hover {\n  transform: translateY(-2px);\n  box-shadow: 0 5px 20px rgba(102, 126, 234, 0.4);\n}\n\n.register-link {\n  text-align: center;\n  margin-top: 1.5rem;\n  color: #666;\n}\n\n.register-link a {\n  color: #667eea;\n  text-decoration: none;\n  font-weight: 500;\n}\n\n.register-link a:hover {\n  text-decoration: underline;\n}\n</style>"]}]}